{
  "name": "vanilla-ts-playgroud",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.0.0",
    "@types/nodemailer": "8.0.1",
    "better-npm-audit": "3.11.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "prettier": "3.8.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "sass": "1.101.0",
    "stylelint": "17.13.0",
    "stylelint-config-prettier-scss": "1.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "terser": "5.48.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.0.16",
    "vite-plugin-checker": "0.14.4"
  },
  "dependencies": {
    "axios": "1.18.1",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "nodemailer": "9.0.1",
    "zod": "4.4.3"
  },
  "scripts": {
    "better-audit": "node node_modules/better-npm-audit audit --production",
    "build": "tsc && vite build",
    "check-dependencies": "node ci/check-dependencies.ts",
    "check-project": "npm run check-dependencies && npm run lint && npm run ts",
    "lint": "eslint src --max-warnings 0",
    "prettier": "prettier --write ./src",
    "preview": "vite build --mode preview && vite preview",
    "server": "tsx --env-file=.env.server ./src/mail/server.ts",
    "start": "vite",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint-check": "stylelint-config-prettier-scss-check",
    "test-all": "npm run check-dependencies && npm run lint && npm run ts",
    "ts": "tsc --version && tsc"
  }
}
