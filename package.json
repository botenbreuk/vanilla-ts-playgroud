{
  "name": "vanilla-ts-playgroud",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "24.10.1",
    "@types/nodemailer": "7.0.4",
    "better-npm-audit": "3.11.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.1",
    "eslint-plugin-import": "2.32.0",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "4.3.0",
    "sass": "1.94.2",
    "terser": "5.44.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.47.0",
    "vite": "7.2.4",
    "vite-plugin-checker": "0.11.0"
  },
  "dependencies": {
    "axios": "1.13.2",
    "date-fns": "4.1.0",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "nodemailer": "7.0.10",
    "zod": "4.1.12"
  },
  "scripts": {
    "better-audit": "node node_modules/better-npm-audit audit --production",
    "build": "tsc && vite build",
    "check-dependencies": "node ci/check-dependencies.ts",
    "check-project": "npm run check-dependencies && npm run lint && npm run ts",
    "lint": "eslint src --max-warnings 0",
    "prettier": "prettier --write ./src",
    "preview": "vite build --mode preview && vite preview",
    "server": "tsx --env-file=.env.server ./src/mail/server.ts",
    "start": "vite",
    "test-all": "npm run check-dependencies && npm run lint && npm run ts",
    "ts": "tsc --version && tsc"
  }
}
